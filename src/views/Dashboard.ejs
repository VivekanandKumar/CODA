<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <title><%= title %></title>
  </head>
  <body>
    <style>
      .unused{
        
      }
    </style>
    <main class="container">
      <h2>Docs List</h2>
      <table class="table">
        <thead>
          <tr>
            <th scope="col">Title</th>
            <th scope="col">Created At</th>
            <th scope="col">Last Updated At</th>
            <th scope="col">Action Required</th>
            <th scope="col">Flagged Message</th>
          </tr>
        </thead>
        <tbody>
          <% docs.forEach((doc)=>{ %>
            <tr class="<%= doc.unused ? 'table-danger':''  %>">
              <td><%= doc.name %></td>
              <td><%= new Date(doc.createdAt).toLocaleString() %></td>
              <td><%= new Date(doc.updatedAt).toLocaleString() %></td>
              <td><%= doc.issue ? 'Yes':'No' %></td>
              <td><%= doc.issue ? doc.issue.map(e=>e.messages.join(', ')) + ' Found in this Doc': '' %></td>
              <td>
                <% if(doc.issue){ %>
                  <button class="btn btn-primary" onclick="handleRowDelete('<%= JSON.stringify(doc.issue) %>')">Delete Rows</button>
                  <%}%>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </main>
    <script>
      async function handleRowDelete(_issue){
        const issues = JSON.parse(_issue);
        for (const issue of issues) {
          await deleteRow(issue.rowId, issue.docId, issue.tableId)
        }
        alert("Action Performed Successfully")
      }

      async function deleteRow(rowId, docId, tableId) {
        try {
          const response = await fetch(
            `http://localhost:3001/row/${docId}/${tableId}/${rowId}`,
            {
              method: 'DELETE',
            }
          );
          
          if (!response.ok) {
            throw new Error(`Failed to delete row: ${response.status}`);
          }
        } catch (error) {
          console.error("Delete error:", error);
        }
    }
    </script>
  </body>
</html>
